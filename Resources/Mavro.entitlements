<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Sandbox disabled for v1 local/unsigned distribution, matching the
         proven Lekho setup. Revisit (enable app-sandbox + Mach service
         entitlement) when moving to notarized/App Store distribution. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
